
                <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
                <head>
                    <!--[if gte mso 9]>
                    <xml>
                        <w:WordDocument>
                            <w:View>Print</w:View>
                            <w:Zoom>100</w:Zoom>
                            <w:DoNotOptimizeForBrowser/>
                        </w:WordDocument>
                    </xml>
                    <![endif]-->
                    <meta charset="utf-8">
                    
                <style>
                    body { font-family: 'Calibri', 'Arial', sans-serif; font-size: 11pt; color: #1a202c; line-height: 1.5; }
                    .resume-header { text-align: center; border-bottom: 2px solid #0f172a; padding-bottom: 15px; margin-bottom: 20px; }
                    .resume-name { font-size: 26pt; font-weight: bold; color: #0f172a; text-transform: uppercase; margin:0 0 5px 0;}
                    .resume-title { font-size: 13pt; font-weight: bold; color: #0284c7; text-transform: uppercase; margin:0 0 12px 0;}
                    .resume-contact { font-size: 10pt; color: #475569; margin: 5px 0; }
                    .resume-section-title { font-size: 12pt; font-weight: bold; color: #0f172a; border-bottom: 1px solid #cbd5e1; padding-bottom: 4px; margin-top: 22px; margin-bottom: 12px; text-transform: uppercase; }
                    .resume-summary-text { color: #334155; margin-bottom: 15px; }
                    .resume-skills-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
                    .resume-skills-table td { padding: 6px 10px; vertical-align: top; border-bottom: 1px solid #f1f5f9; }
                    .resume-skills-category { font-weight: bold; color: #0f172a; width: 25%; }
                    .resume-skills-list { color: #334155; width: 75%; }
                    .resume-project-block { margin-bottom: 18px; }
                    .resume-project-header { display: table; width: 100%; margin-bottom: 5px; }
                    .resume-project-title { display: table-cell; font-weight: bold; color: #0f172a; font-size: 11pt; }
                    .resume-project-date { display: table-cell; text-align: right; font-style: italic; color: #64748b; font-size: 9.5pt; }
                    .resume-bullets { margin: 0 0 10px 0; padding-left: 20px; color: #334155; }
                    .resume-bullets li { margin-bottom: 4px; }
                    .resume-highlight { font-weight: bold; color: #0f172a; }
                </style>
            
                </head>
                <body>
                    
                    
                    <!-- HEADER -->
                    <div class="resume-header">
                        <div class="resume-name" id="resume-name">Shafiq Bhatti</div>
                        <div class="resume-title" id="resume-title">Full Stack Web Developer</div>
                        <div class="resume-contact">
                            <span id="val-address">Karachi, Pakistan</span> &nbsp;|&nbsp; 
                            <span id="val-phone">+92 300 1234567</span> &nbsp;|&nbsp; 
