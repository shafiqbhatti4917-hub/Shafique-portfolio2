                    <!-- CURRENT ACTIVITES -->
                    <div class="resume-section-title">Current Activities &amp; Focus</div>
                    <ul class="resume-bullets">
                        <li><span class="resume-highlight">Advanced Concepts:</span> Actively building intermediate and complex project layers to strengthen Full-Stack implementation.</li>
                        <li><span class="resume-highlight">AI-Assisted Efficiency:</span> Mastering AI tools (ChatGPT, Gemini) to optimize backend code modularity, write test scripts, and accelerate development cycles.</li>
                    </ul>

                    <!-- EDUCATION -->
                    <div class="resume-section-title">Education</div>
                    <div class="resume-project-block" style="margin-bottom: 0;">
                        <div class="resume-project-header">
                            <span class="resume-project-title">Bachelor of Science in Computer Science (BSCS)</span>
