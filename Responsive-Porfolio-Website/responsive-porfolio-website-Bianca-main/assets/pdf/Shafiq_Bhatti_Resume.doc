                        </tr>
                        <tr>
                            <td class="resume-skills-category">Core Expertise</td>
                            <td class="resume-skills-list">Responsive Website Development, RESTful APIs, Clean Architecture, Database Design</td>
                        </tr>
                    </tbody></table>

                    <!-- PROJECTS -->
